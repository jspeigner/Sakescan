{
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/((?!api|assets|data).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/cron/process-images.ts": {
      "maxDuration": 300,
      "memory": 3008
    },
    "api/cron/process-brewery-images.ts": {
      "maxDuration": 120
    }
  },
  "crons": [
    {
      "path": "/api/cron/process-images?chunk=1",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/cron/process-images?chunk=1&mode=discover&speed=accelerated",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/process-brewery-images",
      "schedule": "30 8 * * *"
    }
  ]
}
